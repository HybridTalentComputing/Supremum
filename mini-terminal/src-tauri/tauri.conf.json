{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mini Terminal",
  "version": "0.1.0",
  "identifier": "com.htcmax.mini-terminal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1422",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Mini Terminal",
        "width": 800,
        "height": 600,
        "resizable": true,
        "backgroundColor": "#02070c",
        "titleBarStyle": "Transparent"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
